{"meta":{"version":"121","folder":"EventFlowMsg","file":"Dm_RT_0039","chunk":0,"start":0,"count":12,"total":12},"rows":[{"id":8912,"index":0,"key":"Dm_RT_0039_Near02","CNzh":"你就让我去嘛！","TWzh":"讓我去啦！","JPja":"オイラに<Ruby={2:2}い>行かせてよ！","USen":"You know I can do it!"},{"id":8913,"index":1,"key":"Dm_RT_0039_Text_000_b","CNzh":"我没有逞强！\n我已经是一名战士了！","TWzh":"我又不是辦不到！\n我已經是一名戰士啦！","JPja":"<Ruby={4:4}むり>無理じゃないよ！\nオイラ もう<Ruby={4:6}せんし>戦士なんだ！","USen":"That's not fair at all! You know I can handle it!"},{"id":8914,"index":2,"key":"Dm_RT_0039_Text_001_b","CNzh":"只是去调查那朵巨大的云而已，\n我一个人就能轻松搞定的！","TWzh":"不過就是去調查那片超大的雲而已，\n我一個人處理也是輕輕鬆鬆啊！","JPja":"あのでっかい<Ruby={2:4}くも>雲を<Ruby={2:4}しら>調べるくらい\n<Ruby={4:6}ひとり>一人でだって ヨユーだよ！","USen":"Checking out that huge cloud wouldn't be hard!\nI could even do it alone!"},{"id":8915,"index":3,"key":"Dm_RT_0039_Text_001_c","CNzh":"","TWzh":"","JPja":"","USen":""},{"id":8916,"index":4,"key":"Dm_RT_0039_Text_002_b","CNzh":"再这样拖下去，","TWzh":"再繼續拖拖拉拉下去，","JPja":"もたもたしてたら","USen":"If we don't do anything..."},{"id":8917,"index":5,"key":"Dm_RT_0039_Text_002_c","CNzh":"村子就……","TWzh":"村子就會……","JPja":"<Ruby={2:4}むら>村が…","USen":"the village—"},{"id":8918,"index":6,"key":"Dm_RT_0039_Text_002_d","CNzh":"","TWzh":"","JPja":"","USen":""},{"id":8919,"index":7,"key":"Dm_RT_0039_Text_003_b","CNzh":"<PageBreak>莫非是……？","TWzh":"<PageBreak>那該不會是……？","JPja":"<PageBreak>もしかして…？","USen":"Huh? Is that you?"},{"id":8920,"index":8,"key":"Dm_RT_0039_Text_003_c","CNzh":"","TWzh":"","JPja":"","USen":""},{"id":8921,"index":9,"key":"Dm_RT_0039_Text_003_d","CNzh":"","TWzh":"","JPja":"","USen":""},{"id":8922,"index":10,"key":"Dm_RT_0039_Text_004_b","CNzh":"真的是你！","TWzh":"果然是你！","JPja":"やっぱり！","USen":"It IS you!"},{"id":8923,"index":11,"key":"Dm_RT_0039_Text_005_b","CNzh":"林克！","TWzh":"林克！","JPja":"リンク！","USen":"Link!"}]}